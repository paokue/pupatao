BUNNY_STORAGE_ZONE="storage_zone"
BUNNY_API_KEY="api_key"
BUNNY_CDN_HOST="host_endpoint"
BUNNY_BASE_HOSTNAME="host_name"

# ===========================================
#Pusher
# ===========================================
PUSHER_APP_ID="app_id"
PUSHER_KEY="key"
PUSHER_SECRET="secret"
PUSHER_CLUSTER="cluster"
VITE_PUSHER_KEY="pusher_key"
VITE_PUSHER_CLUSTER="pusher_cluster"

# ===========================================
# Community group invite links (shown in the "Join group" menu)
# ===========================================
VITE_WHATSAPP_GROUP_URL="https://chat.whatsapp.com/DEMO_GROUP_ID"
VITE_MESSENGER_GROUP_URL="https://m.me/j/DEMO_GROUP_ID"

# ======================================================================================
# Symbol bets (1 / 2 / 3 dice match the symbol you bet on)
# ======================================================================================
PAYOUT_SYMBOL_1=number
PAYOUT_SYMBOL_2=number
PAYOUT_SYMBOL_3=number

# ======================================================================================
# Pair bet (both pair symbols rolled — at least once each)
# ======================================================================================
PAYOUT_PAIR=number

# ======================================================================================
# Range bets (sum of 3 dice falls in range)
# ======================================================================================
PAYOUT_RANGE_LOW=number
PAYOUT_RANGE_MIDDLE=number
PAYOUT_RANGE_HIGH=number

# ======================================================================================
# Live-mode promotion toggles (set to true to enable, false or omit to disable)
# ======================================================================================
# Win-streak bonus: +5,000 ₭ on 4 wins in a row; +10,000 ₭ on 5th; streak resets.
PROMO_STREAK=false
# Triple symbol bonus: Crab/Prawn/Gourd triple → ×16 total; Fish/Rooster/Frog → ×10 total
PROMO_TRIPLE=false
# Special SUM bonus: sum 3, 7, 11, 15 → ×6 total return (5× net profit); others unchanged
PROMO_SUM=false